# Copy to .env and adjust (never commit .env)

# Server (Render sets PORT automatically)
PORT=3001

# CORS: your Vercel site origin(s), comma-separated — e.g. https://your-app.vercel.app
# If unset, all origins are allowed (fine for local dev; set this on Render for a private deploy).
CLIENT_ORIGIN=

# Optional — real OpenAI (app falls back to mock if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
