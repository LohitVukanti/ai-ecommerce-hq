# Copy to .env.local for local overrides (never commit secrets)

# Production: full URL of your Render API including /api
# Example: https://ai-ecommerce-hq-api.onrender.com/api
# Leave unset for local dev (Vite proxies /api to localhost:3001)
VITE_API_BASE_URL=

# Optional shared gate password (baked into the client build — use only for demo/private MVP)
VITE_APP_PASSWORD=test123
